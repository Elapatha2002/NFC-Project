# ---- Firebase Admin (service account) ----
# From Firebase console -> Project settings -> Service accounts -> Generate new private key.
# Copy the three values out of the downloaded JSON file.
# NOTE: This is a TEMPLATE that is committed to git. Never put real secrets here.
# Put real values in a local ".env" file (which is gitignored) instead.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Keep the surrounding quotes in .env. Paste the whole private_key value (with the literal \n sequences).
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# ---- Auth ----
# Any long random string. Used to sign admin login tokens.
JWT_SECRET=change-me-to-a-long-random-string

# ---- One-time setup endpoint protection ----
# A secret you choose. Required to call POST /api/setup to create the first admin user.
SETUP_SECRET=change-me-too
